<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slate_50"
    tools:context=".dashboard.VendorDashboardActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vendor Dashboard"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/slate_900"
            android:layout_marginBottom="16dp" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragmentCategory"
            android:name="edu.cit.capendit.unisell.category.ui.CategoryFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragmentPlatform"
            android:name="edu.cit.capendit.unisell.platform.ui.PlatformFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragmentProduct"
            android:name="edu.cit.capendit.unisell.product.ui.ProductFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragmentOrder"
            android:name="edu.cit.capendit.unisell.order.ui.OrderFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

</ScrollView>